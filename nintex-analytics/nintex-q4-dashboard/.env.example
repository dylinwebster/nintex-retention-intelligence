# Copy to .env and fill in values. Never commit .env to Git.

# For local dev: leave blank (data loaded from /public/q4_data.json)
VITE_DATA_URL=

# For production (Vercel Blob): set to your blob URL after creating the store
# VITE_DATA_URL=https://xxxx.public.blob.vercel-storage.com/q4_data.json

# Anthropic API key - set this in Vercel environment variables, not here
# ANTHROPIC_API_KEY=sk-ant-...
